# Origen de datos de la SPA (Demo-First v2).
#   no definido / != "false"  ->  MOCK (db.json en memoria) — default del demo (Fase 1)
#   "false"                   ->  API real CI4 (Fase 2)
VITE_USE_MOCK=true

# Base de la API real (solo aplica con VITE_USE_MOCK=false). Default: /api/v1
VITE_API_BASE_URL=/api/v1
