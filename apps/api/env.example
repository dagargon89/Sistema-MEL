#--------------------------------------------------------------------
# Sistema MEL — API (CodeIgniter 4). Copia a `.env` y rellena secretos:
#   cp env.example .env
# Nunca subas `.env` al repositorio.
#--------------------------------------------------------------------

CI_ENVIRONMENT = development

#--------------------------------------------------------------------
# APP
#--------------------------------------------------------------------
app.baseURL = 'http://localhost:8080/'
# Forzar HTTPS en staging/producción (doc 04 §6.3):
# app.forceGlobalSecureRequests = true

#--------------------------------------------------------------------
# BASE DE DATOS — MySQL 8 (única fuente de verdad)
#--------------------------------------------------------------------
database.default.hostname = 127.0.0.1
database.default.database = sistema_mel
database.default.username = mel
database.default.password = mel_secret
database.default.DBDriver = MySQLi
database.default.port = 3306

# Base de pruebas (PHPUnit / conciliación):
database.tests.hostname = 127.0.0.1
database.tests.database = sistema_mel_test
database.tests.username = mel
database.tests.password = mel_secret
database.tests.DBDriver = MySQLi
database.tests.port = 3306

#--------------------------------------------------------------------
# SEGURIDAD / ENCRIPTACIÓN (generar con: php spark key:generate)
#--------------------------------------------------------------------
# encryption.key =

#--------------------------------------------------------------------
# CORS — origen(es) de la SPA (doc 04). Lista separada por comas.
# Lo lee app/Config/Cors.php. En producción, el dominio HTTPS de la SPA.
#--------------------------------------------------------------------
CORS_ALLOWED_ORIGINS = http://localhost:5173

#--------------------------------------------------------------------
# REDIS — caché, cola y throttle
#--------------------------------------------------------------------
redis.host = 127.0.0.1
redis.port = 6379
# redis.password =
